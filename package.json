{
  "name": "focusflow",
  "version": "0.1.0",
  "description": "A local-first Windows desktop Pomodoro timer.",
  "main": "output/build/main/index.js",
  "type": "module",
  "author": {
    "name": "Github Gis2all"
  },
  "license": "MIT",
  "scripts": {
    "dev": "cmd /d /s /c \"set ELECTRON_RUN_AS_NODE=&& electron-vite dev --watch\"",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "cmd /d /s /c \"set ELECTRON_RUN_AS_NODE=&& electron-vite preview\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && node ./package-win.mjs",
    "package:appx:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\appx\\package-dev.ps1"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "@swc/core": "^1.10.7",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.focusflow.timer",
    "productName": "FocusFlow",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "directories": {
      "output": "output/release",
      "buildResources": "main/assets"
    },
    "extraResources": [
      {
        "from": "main/assets",
        "to": "app-assets",
        "filter": [
          "focusflow-icon.png",
          "focusflow-icon.ico",
          "focusflow-tray.png",
          "focusflow-tray-dark.png"
        ]
      }
    ],
    "files": [
      "output/build/**/*",
      "package.json"
    ],
    "win": {
      "icon": "main/assets/focusflow-icon.ico",
      "executableName": "focusflow",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "focusflow-setup.${ext}",
      "uninstallDisplayName": "FocusFlow"
    },
    "portable": {
      "artifactName": "focusflow-single.${ext}"
    },
    "appx": {
      "identityName": "FocusFlow.Desktop",
      "applicationId": "FocusFlow",
      "displayName": "FocusFlow",
      "backgroundColor": "transparent",
      "publisherDisplayName": "Github Gis2all",
      "publisher": "CN=gis2all",
      "artifactName": "focusflow-appx.${ext}"
    }
  }
}
